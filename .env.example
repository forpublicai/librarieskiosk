# Database (NeonDB or local PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# nano-gpt API Key (server-side only, never exposed to browser)
# Fallback key — used when a library-scoped key below is unset.
NANOGPT_API_KEY="sk-nano-your-key-here"

# Per-library nano-gpt API keys (optional). Each library's generation requests
# are routed through its own key so usage on the nano-gpt dashboard is split
# per library. Env var name format: NANOGPT_API_KEY_<SLUG>, where SLUG is the
# library name uppercased with non-alphanumerics collapsed to `_`.
# Examples:
#   "Pottsboro, TX"   -> NANOGPT_API_KEY_POTTSBORO_TX
#   "Salem City, UT"  -> NANOGPT_API_KEY_SALEM_CITY_UT
NANOGPT_API_KEY_POTTSBORO_TX=""
NANOGPT_API_KEY_SALEM_CITY_UT=""

# JWT Secret (generate a strong random string, e.g.: openssl rand -hex 32)
JWT_SECRET="CHANGE-ME-generate-a-strong-random-secret"

# Seed script credentials (change these before deploying)
ADMIN_PASSWORD="CHANGE-ME-strong-admin-password"
PATRON_PASSWORD="CHANGE-ME-strong-patron-password"

# Kiosk access gate (optional — leave unset to disable in dev/preview)
# Set this to a secret random string. The kiosk device's browser homepage must be:
#   https://your-deployment.vercel.app/?access=YOUR_TOKEN_HERE
# Anyone hitting the plain URL without the cookie gets a 403.
# Rotate this value + redeploy + update the browser homepage to revoke leaked tokens.
KIOSK_ACCESS_TOKEN=""

# Per-library kiosk bootstrap URL (no env var needed — ops-only note).
# To isolate guest credit pools and NanoGPT usage per library on a single
# shared deployment, each kiosk device should be provisioned with a start URL
# that includes the library slug:
#   https://<host>/l/<slug>?access=YOUR_TOKEN_HERE
# where <slug> is the lowercase library name with non-alphanumerics as `_`:
#   "Pottsboro, TX"  -> pottsboro_tx
#   "Salem City, UT" -> salem_city_ut
#   "Public AI"      -> public_ai
# Visiting `/l/<slug>` sets a `kiosk_library` cookie (8h) that routes
# guest logins to that library's dedicated guest account.
# Kiosks that keep hitting the bare URL still work — they fall back to the
# shared legacy `guest` account.

# Cloudflare R2 (durable media storage for generated images, music, video)
# Create a bucket in Cloudflare dashboard, mint an S3 API token, then paste:
R2_ACCOUNT_ID=""
R2_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
R2_BUCKET=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# Signed GET URL TTL in seconds (default 3600 = 1 hour; frontend refreshes on 403)
R2_SIGNED_URL_TTL_SECONDS="3600"
# Maximum bytes accepted from provider downloads (default 100 MB)
R2_MAX_UPLOAD_BYTES="104857600"
# Feature flag — flip to "true" to enable R2 persistence in generation routes
USE_R2_PERSISTENCE="false"
